{
  "openapi": "3.0.0",
  "info": {
    "title": "Cosmetics SaaS API Documentation",
    "version": "1.0.0",
    "description": "API Documentation for Auth, Ingredients, Formulas, and MBR Modules"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    },
    {
      "url": "http://34.224.21.211",
