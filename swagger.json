  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SignupRequest": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "companyName",
          "country",
          "email",
          "password",
          "confirmPassword"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          },
          "companyName": {
            "type": "string",
            "example": "Tech Corp"
          },
          "country": {
            "type": "string",
            "example": "Egypt"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "Password123!"
          },
          "confirmPassword": {
            "type": "string",
            "format": "password",
            "example": "Password123!"
          },
          "phone": {
            "type": "string",
            "example": "+201000000000"
          }
        }
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": [
          "email",
          "otp"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "otp": {
            "type": "string",
            "example": "123456"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "Password123!"
          }
        }
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": [
          "email",
          "otp",
          "newPassword",
          "confirmPassword"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "otp": {
            "type": "string",
            "example": "123456"
          },
          "newPassword": {
            "type": "string",
            "format": "password",
            "example": "NewPassword123!"
          },
          "confirmPassword": {
            "type": "string",
            "format": "password",
            "example": "NewPassword123!"
          }
        }
      },
      "GoogleAuthRequest": {
        "type": "object",
        "required": [
          "idToken"
        ],
        "properties": {
          "idToken": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIs..."
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "iconEnum": {
            "type": "string"
          },
          "activeStatus": {
            "type": "boolean"
          }
        }
      },
      "Ingredient": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "commercialName": {
            "type": "string"
          },
          "inciName": {
            "type": "string"
          },
          "internalCode": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          }
        }
      },
      "Phase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "Formula": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "formulaName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "targetBatchSize": {
            "type": "number"
          }
        }
      },
      "MBR": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "mbrCode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "revision": {
            "type": "string"
          }
        }
      },
      "CreateFormulaRequest": {
        "type": "object",
        "required": [
          "formulaName",
          "category",
          "formulaType",
          "targetBatchSize"
        ],
        "properties": {
          "formulaName": {
            "type": "string",
            "example": "My Custom Lotion"
          },
          "category": {
            "type": "string",
            "example": "Skincare"
          },
          "formulaType": {
            "type": "string",
            "example": "O/W Emulsion (Oil in Water)"
          },
          "targetBatchSize": {
            "type": "number",
            "example": 100
          },
          "measurementUnit": {
            "type": "string",
            "example": "kg"
          },
          "targetpHMin": {
            "type": "number",
            "example": 5
          },
          "targetpHMax": {
            "type": "number",
            "example": 6
          },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phaseId": {
                  "type": "string"
                },
                "phaseName": {
                  "type": "string"
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "ingredientId": {
                        "type": "string"
                      },
                      "targetPercentage": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "CreateTemplateRequest": {
        "type": "object",
        "required": [
          "templateName",
          "category",
          "formulaType",
          "packageId"
        ],
        "properties": {
          "templateName": {
            "type": "string",
            "example": "Luxury Hydrating Serum"
          },
          "category": {
            "type": "string",
            "example": "Skincare"
          },
          "formulaType": {
            "type": "string",
            "example": "Serum"
          },
          "packageId": {
            "type": "string",
            "example": "64a2f9b8c3f4e2a1b2c3d4e5"
          },
          "description": {
            "type": "string",
            "example": "Premium hydrating serum"
          },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phaseId": {
                  "type": "string",
                  "example": "64a2f9b8c3f4e2a1b2c3d4e6"
                },
                "phaseName": {
                  "type": "string",
                  "example": "Water Phase"
                },
                "minPercentage": {
                  "type": "number",
                  "example": 0
                },
                "maxPercentage": {
                  "type": "number",
                  "example": 98
                }
              }
            }
          },
          "methodSteps": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "Heat to 75C"
            }
          },
          "activeStatus": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "CreatePackageRequest": {
        "type": "object",
        "required": [
          "name",
          "price"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Complete Access"
          },
          "description": {
            "type": "string",
            "example": "All features"
          },
          "price": {
            "type": "number",
            "example": 599
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "AI Co-pilot"
            }
          }
        }
      },
      "CreatePhaseRequest": {
        "type": "object",
        "required": [
          "name",
          "code"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Water Phase"
          },
          "code": {
            "type": "string",
            "example": "PHASE-A"
          },
          "description": {
            "type": "string",
            "example": "Base and solvent system"
          },
          "assignedCategories": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "64a2f9b8c3f4e2a1b2c3d4e5"
            }
          }
        }
      },
      "CreateCategoryRequest": {
        "type": "object",
        "required": [
          "name",
          "code"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Solvents"
          },
          "code": {
            "type": "string",
            "example": "SOLV"
          },
          "description": {
            "type": "string",
            "example": "Primary solvents for formulas"
          },
          "displayOrder": {
            "type": "number",
            "example": 1
          },
          "iconEnum": {
            "type": "string",
            "example": "Water"
          },
          "isMinAllowed": {
            "type": "boolean",
            "example": true
          },
          "isMaxAllowed": {
            "type": "boolean",
            "example": true
          },
          "isRequiredFormula": {
            "type": "boolean",
            "example": false
          },
          "isAutoValidationEnabled": {
            "type": "boolean",
            "example": true
          },
          "activeStatus": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "CreateIngredientRequest": {
        "type": "object",
        "required": [
          "commercialName",
          "inciName",
          "categoryId",
          "internalCode"
        ],
        "properties": {
          "commercialName": {
            "type": "string",
            "example": "Purified Water"
          },
          "inciName": {
            "type": "string",
            "example": "Aqua"
          },
          "categoryId": {
            "type": "string",
            "example": "64a2f9b8c3f4e2a1b2c3d4e5"
          },
          "internalCode": {
            "type": "string",
            "example": "AQ-001"
          },
          "supplier": {
            "type": "string",
            "example": "Local Supplier"
          },
          "primaryFunction": {
            "type": "string",
            "example": "Solvent"
          },
          "usageGuidelines": {
            "type": "object",
            "properties": {
              "minPercentage": {
                "type": "number",
                "example": 0
              },
              "maxPercentage": {
                "type": "number",
                "example": 80
              },
              "defaultPercentage": {
                "type": "number",
                "example": 50
              },
              "pHMin": {
                "type": "number",
                "example": 5
              },
              "pHMax": {
                "type": "number",
                "example": 7
              },
              "tempStabilityValue": {
                "type": "number",
                "example": 100
              },
              "solubility": {
                "type": "string",
                "example": "Water Soluble"
              }
            }
          },
          "originSource": {
            "type": "string",
            "example": "Natural Origin"
          },
          "compatibilityScore": {
            "type": "number",
            "example": 100
          }
        }
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "User Signup",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "400": {
            "description": "Validation Error / Passwords do not match"
          }
        }
      }
    },
    "/auth/verify-email": {
      "post": {
        "summary": "Verify Email with OTP",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email verified successfully"
          },
          "400": {
            "description": "Invalid OTP or Email"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "User Login",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login, returns JWT token"
          },
          "401": {
            "description": "Unauthorized / Invalid credentials"
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "summary": "Forgot Password",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent to email"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "summary": "Reset Password with OTP",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully"
          },
          "400": {
            "description": "Invalid OTP or passwords do not match"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "User Logout",
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully logged out"
          },
          "401": {
            "description": "Unauthorized / Token missing or invalid"
          }
        }
      }
    },
    "/auth/google": {
      "post": {
        "summary": "Google Authentication",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated via Google"
          },
          "400": {
            "description": "Invalid token"
          }
        }
      }
    },
